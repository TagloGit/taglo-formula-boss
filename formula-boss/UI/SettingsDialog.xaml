<Window x:Class="FormulaBoss.UI.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formula Boss Settings"
        Width="340" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1a2e"
        Foreground="#cccccc"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cccccc" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Match the EditorButton style from FloatingEditorWindow -->
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <!-- Bottom: OK / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Style="{StaticResource DialogButton}"
                    Background="#c2410c" Foreground="White"
                    BorderThickness="0"
                    Click="OnOk" IsDefault="True" />
            <Button Content="Cancel" Style="{StaticResource DialogButton}"
                    Background="#3a3a50" Foreground="#cccccc"
                    BorderThickness="0"
                    Click="OnCancel" IsCancel="True" />
        </StackPanel>

        <!-- Settings grid -->
        <Grid VerticalAlignment="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Animation"
                       Style="{StaticResource LabelStyle}" />
            <ComboBox x:Name="AnimationCombo" Grid.Row="0" Grid.Column="1"
                      Style="{StaticResource ComboStyle}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Indent size"
                       Style="{StaticResource LabelStyle}" />
            <TextBox x:Name="IndentSizeBox" Grid.Row="2" Grid.Column="1"
                     Width="60" HorizontalAlignment="Left"
                     VerticalContentAlignment="Center"
                     Height="26" />
        </Grid>
    </DockPanel>
</Window>
